import { useState, useEffect } from "react"
import { addPropertyControls, ControlType } from "framer"

// Configuration (Remets tes identifiants ici)
const CLIENT_ID = "52e4cad9a2554fa79baa063119be89cb"
const CLIENT_SECRET = "6dd493ab12eb407890d4b06a0d8875eb"

// Liste des filtres disponibles
const FILTERS = ["Toutes", "Podcasts", "Exercices", "Articles", "Témoignages"]

export default function SpotifyAdvancedList(props) {
    const { searchTerm, limit } = props
    const [podcasts, setPodcasts] = useState([])
    const [loading, setLoading] = useState(true)
    const [expandedId, setExpandedId] = useState(null)
    const [hoveredId, setHoveredId] = useState(null)

    // NOUVEAU : Gère le filtre actif
    const [activeFilter, setActiveFilter] = useState("Toutes")

    useEffect(() => {
        async function getSpotifyData() {
            try {
                const authResponse = await fetch(
                    "https://accounts.spotify.com/api/token",
                    {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded",
                            Authorization:
                                "Basic " +
                                btoa(CLIENT_ID + ":" + CLIENT_SECRET),
                        },
                        body: "grant_type=client_credentials",
                    }
                )
                const authData = await authResponse.json()
                const token = authData.access_token

                const searchResponse = await fetch(
                    `https://api.spotify.com/v1/search?q=$${encodeURIComponent(searchTerm)}&type=show&market=FR&limit=${limit}`,
                    { headers: { Authorization: `Bearer ${token}` } }
                )
                const searchData = await searchResponse.json()
                setPodcasts(searchData.shows.items)
                setLoading(false)
            } catch (error) {
                console.error("Erreur Spotify:", error)
                setLoading(false)
            }
        }
        getSpotifyData()
    }, [searchTerm, limit])

    const toggleExpand = (id, e) => {
        e.preventDefault()
        setExpandedId(expandedId === id ? null : id)
    }

    if (loading)
        return <div style={centerStyle}>Chargement des ressources...</div>

    // Détermine si on doit afficher la liste Spotify ou l'état vide
    const showPodcasts =
        activeFilter === "Toutes" || activeFilter === "Podcasts"

    return (
        <div style={containerStyle}>
            {/* En-tête principal */}
            <div style={headerStyle}>
                <h2 style={mainTitleStyle}>Ma sélection Bien-être</h2>
                <p style={subtitleStyle}>Contenus inspirants et positifs</p>
            </div>

            {/* Bannière Contenus inspirants */}
            <div style={inspiringContentBlockStyle}>
                <div style={iconContainerStyle}>
                    <div style={iconBgStyle}>
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path
                                d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
                                fill="#D4A33B"
                            />
                        </svg>
                    </div>
                </div>
                <div style={textContentStyle}>
                    <h3 style={infoTitleStyle}>
                        Contenus inspirants et positifs
                    </h3>
                    <p style={infoDescriptionStyle}>
                        Découvre des contenus pour t'inspirer, te détendre et
                        mieux comprendre la santé mentale.
                    </p>
                </div>
            </div>

            {/* Filtres cliquables */}
            <div style={filtersContainer}>
                {FILTERS.map((filterName) => (
                    <span
                        key={filterName}
                        onClick={() => setActiveFilter(filterName)}
                        style={{
                            ...filterPill,
                            ...(activeFilter === filterName
                                ? activeFilterPill
                                : {}),
                        }}
                    >
                        {filterName}
                    </span>
                ))}
            </div>

            {/* Contenu Conditionnel basé sur le filtre */}
            <div style={listContainer}>
                {showPodcasts ? (
                    // Affichage de la liste Spotify
                    podcasts.map((podcast) => {
                        const isExpanded = expandedId === podcast.id
                        const isHovered = hoveredId === podcast.id

                        return (
                            <div
                                key={podcast.id}
                                style={{
                                    ...cardWrapperStyle,
                                    transform:
                                        isHovered && !isExpanded
                                            ? "translateY(-2px)"
                                            : "translateY(0)",
                                    boxShadow:
                                        isHovered || isExpanded
                                            ? "0px 8px 24px rgba(0,0,0,0.06)"
                                            : "0px 2px 8px rgba(0,0,0,0.03)",
                                }}
                                onMouseEnter={() => setHoveredId(podcast.id)}
                                onMouseLeave={() => setHoveredId(null)}
                            >
                                <div
                                    style={cardTopStyle}
                                    onClick={(e) => toggleExpand(podcast.id, e)}
                                >
                                    <div style={imageContainerStyle}>
                                        <img
                                            src={podcast.images[0]?.url}
                                            style={imageStyle}
                                            alt={podcast.name}
                                        />
                                        <div style={badgeStyle}>
                                            <svg
                                                width="12"
                                                height="12"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="black"
                                                strokeWidth="2"
                                                strokeLinecap="round"
                                                strokeLinejoin="round"
                                            >
                                                <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
                                                <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path>
                                            </svg>
                                        </div>
                                        {isExpanded && (
                                            <div style={playOverlayStyle}>
                                                <svg
                                                    width="24"
                                                    height="24"
                                                    viewBox="0 0 24 24"
                                                    fill="white"
                                                >
                                                    <path d="M5 3l14 9-14 9V3z" />
                                                </svg>
                                            </div>
                                        )}
                                    </div>

                                    <div style={textContainerStyle}>
                                        <h4 style={titleStyle}>
                                            {podcast.name}
                                        </h4>
                                        <p style={descriptionStyle}>
                                            {podcast.description ||
                                                "Découvre ce contenu inspirant."}
                                        </p>
                                        <div style={metaContainerStyle}>
                                            <span style={metaItemStyle}>
                                                <svg
                                                    width="12"
                                                    height="12"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    strokeWidth="2"
                                                >
                                                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                                                    <line
                                                        x1="7"
                                                        y1="7"
                                                        x2="7.01"
                                                        y2="7"
                                                    ></line>
                                                </svg>
                                                Podcast {podcast.publisher}
                                            </span>
                                            <span style={metaItemStyle}>
                                                <svg
                                                    width="12"
                                                    height="12"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    strokeWidth="2"
                                                >
                                                    <circle
                                                        cx="12"
                                                        cy="12"
                                                        r="10"
                                                    ></circle>
                                                    <polyline points="12 6 12 12 16 14"></polyline>
                                                </svg>
                                                25 min
                                            </span>
                                        </div>
                                    </div>

                                    <div style={arrowContainerStyle}>
                                        <svg
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="#999"
                                            strokeWidth="2"
                                            strokeLinecap="round"
                                            strokeLinejoin="round"
                                            style={{
                                                transform: isExpanded
                                                    ? "rotate(90deg)"
                                                    : "rotate(0deg)",
                                                transition: "0.2s",
                                            }}
                                        >
                                            <polyline points="9 18 15 12 9 6"></polyline>
                                        </svg>
                                    </div>
                                </div>

                                {isExpanded && (
                                    <div style={expandedSectionStyle}>
                                        <a
                                            href={podcast.external_urls.spotify}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            style={primaryLinkStyle}
                                        >
                                            Accéder au contenu
                                            <svg
                                                width="14"
                                                height="14"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                strokeWidth="2"
                                                strokeLinecap="round"
                                                strokeLinejoin="round"
                                            >
                                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                                <polyline points="15 3 21 3 21 9"></polyline>
                                                <line
                                                    x1="10"
                                                    y1="14"
                                                    x2="21"
                                                    y2="3"
                                                ></line>
                                            </svg>
                                        </a>
                                        <button style={secondaryButtonStyle}>
                                            Aperçu
                                        </button>
                                    </div>
                                )}
                            </div>
                        )
                    })
                ) : (
                    // Affichage de l'état vide pour les autres filtres
                    <div style={emptyStateStyle}>
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="#CCC"
                            strokeWidth="2"
                            strokeLinecap="round"
                            strokeLinejoin="round"
                            style={{ marginBottom: "8px" }}
                        >
                            <rect
                                x="3"
                                y="3"
                                width="18"
                                height="18"
                                rx="2"
                                ry="2"
                            ></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                        <p
                            style={{
                                margin: 0,
                                fontWeight: "500",
                                color: "#666",
                            }}
                        >
                            Contenu à venir
                        </p>
                        <p
                            style={{
                                margin: "4px 0 0 0",
                                fontSize: "14px",
                                color: "#999",
                            }}
                        >
                            Nous préparons cette section pour bientôt.
                        </p>
                    </div>
                )}
            </div>
        </div>
    )
}

